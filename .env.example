# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=benchbridge

# ─── Backend / FastAPI ────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/benchbridge
SECRET_KEY=replace_with_64_random_hex_characters
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
FRONTEND_URL=http://localhost

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Leave blank to print OTPs to the backend console (dev mode)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ─── For Gmail SMTP example ───────────────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASSWORD=your_app_password   # Generate at myaccount.google.com/apppasswords
